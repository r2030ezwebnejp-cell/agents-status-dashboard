---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const statusPath = path.join(process.cwd(), 'public/data/status.json');
const statusData = JSON.parse(fs.readFileSync(statusPath, 'utf-8'));

const newsPath = path.join(process.cwd(), 'public/data/news.json');
const newsData = JSON.parse(fs.readFileSync(newsPath, 'utf-8'));
const latestNews = [...newsData.posts].sort((a: any, b: any) => (a.date < b.date ? 1 : -1)).slice(0, 3);

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.endsWith('/') ? base : base + '/'}${p}`;
---
<BaseLayout title="トップ" description="Agent Lab — 6体のAIエージェントが動く実験場">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-content">
      <h1>The Future Begins with AI</h1>
      <p>6体のAIエージェントが、毎日自律的に稼働しています。</p>
      <a class="cta" href={withBase('dashboard/')}>稼働状況を見る →</a>
    </div>
  </section>

  <section class="agents">
    <h2>6体のエージェント</h2>
    <div class="agent-grid">
      {statusData.agents.map((a: any) => (
        <a class="agent-card" href={withBase('services/')}>
          <span class="agent-id">{a.id}</span>
          <span class="agent-name">{a.name}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="summary">
    <h2>稼働実績サマリー</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>エージェント</th><th>直近実行</th><th>累計稼働回数</th></tr>
        </thead>
        <tbody>
          {statusData.agents.map((a: any) => {
            const runs = a.runs || [];
            const last = runs.length
              ? [...runs].sort((x: any, y: any) => (x.timestamp < y.timestamp ? 1 : -1))[0]
              : null;
            return (
              <tr>
                <td>{a.id}. {a.name}</td>
                <td>{last ? formatDate(last.timestamp) : '記録なし'}</td>
                <td>{runs.length}回</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="news">
    <h2>お知らせ</h2>
    {latestNews.length === 0 ? (
      <p class="empty">まだお知らせはありません。</p>
    ) : (
      <ul>
        {latestNews.map((p: any) => (
          <li><time>{formatDate(p.date)}</time><span>{p.title}</span></li>
        ))}
      </ul>
    )}
    <a class="more" href={withBase('news/')}>お知らせ一覧を見る →</a>
  </section>

  <section class="cta-section">
    <h2>もっと知りたい方へ</h2>
    <div class="cta-links">
      <a href={withBase('works/')}>実績一覧を見る</a>
      <a href={withBase('contact/')}>お問い合わせ</a>
    </div>
  </section>
</BaseLayout>

<style>
  section { margin-bottom: 52px; }
  h2 { font-size: 1.15rem; margin: 0 0 16px; }

  .hero {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    padding: 64px 28px;
    margin-bottom: 52px;
    color: #fff;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(255,255,255,0.18), transparent 45%),
      radial-gradient(circle at 85% 80%, rgba(255,255,255,0.14), transparent 50%),
      linear-gradient(135deg, #1D5FD6 0%, #1440a0 60%, #0d2a6b 100%);
  }
  .hero-content { position: relative; max-width: 46ch; }
  .hero h1 {
    font-size: 2.1rem;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .hero p {
    font-size: 1rem;
    opacity: 0.9;
    margin: 0 0 24px;
  }
  .cta {
    display: inline-block;
    background: #fff;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 10px 22px;
    border-radius: 999px;
    text-decoration: none;
  }

  .agent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .agent-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--text);
  }
  .agent-card:hover { border-color: var(--accent); }
  .agent-id {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
  }
  .agent-name { font-size: 0.88rem; font-weight: 600; }

  .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 10px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th, td { text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--border); }
  th { font-size: 0.7rem; color: var(--text-sub); text-transform: uppercase; letter-spacing: 0.04em; }
  tr:last-child td { border-bottom: none; }

  .news ul { list-style: none; margin: 0 0 12px; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .news li { display: flex; gap: 14px; font-size: 0.88rem; }
  .news time { color: var(--text-sub); font-size: 0.78rem; white-space: nowrap; }
  .news .empty { font-size: 0.88rem; color: var(--text-sub); }
  .more { font-size: 0.85rem; color: var(--accent); text-decoration: none; }

  .cta-links { display: flex; gap: 14px; flex-wrap: wrap; }
  .cta-links a {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 8px 18px;
    border-radius: 999px;
    text-decoration: none;
  }
  .cta-links a:hover { background: var(--accent-soft); }
</style>
