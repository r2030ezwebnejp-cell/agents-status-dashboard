---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const statusPath = path.join(process.cwd(), 'public/data/status.json');
const statusData = JSON.parse(fs.readFileSync(statusPath, 'utf-8'));

const newsPath = path.join(process.cwd(), 'public/data/news.json');
const newsData = JSON.parse(fs.readFileSync(newsPath, 'utf-8'));
const latestNews = [...newsData.posts].sort((a: any, b: any) => (a.date < b.date ? 1 : -1)).slice(0, 3);

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.endsWith('/') ? base : base + '/'}${p}`;
---
<BaseLayout title="トップ" description="Agent Lab — 6体のAIエージェントが動く実験場">
  <section class="hero">
    <div
      class="hero-bg"
      aria-hidden="true"
      style={`background: linear-gradient(100deg, rgba(10,16,30,0.72) 0%, rgba(10,16,30,0.42) 42%, rgba(10,16,30,0.15) 68%), url(${withBase('images/hero.jpg')}) center 72% / cover no-repeat;`}
    ></div>
    <div class="hero-content">
      <h1>The Future Begins with AI</h1>
      <p class="tagline">未来は、AIから始まる。</p>
      <a class="cta" href={withBase('dashboard/')}>稼働状況を見る →</a>
    </div>
  </section>

  <section class="agents">
    <h2>My Agent</h2>
    <div class="agent-grid">
      {statusData.agents.map((a: any) => (
        <a class="agent-card" href={withBase(`agents/${a.id}/`)}>
          <span class="agent-name">{a.name}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="summary">
    <h2>稼働実績サマリー</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>エージェント</th><th>直近実行</th><th>累計稼働回数</th></tr>
        </thead>
        <tbody>
          {statusData.agents.map((a: any) => {
            const runs = a.runs || [];
            const last = runs.length
              ? [...runs].sort((x: any, y: any) => (x.timestamp < y.timestamp ? 1 : -1))[0]
              : null;
            return (
              <tr>
                <td>{a.name}</td>
                <td>{last ? formatDate(last.timestamp) : '記録なし'}</td>
                <td>{runs.length}回</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="news">
    <h2>News</h2>
    {latestNews.length === 0 ? (
      <p class="empty">まだお知らせはありません。</p>
    ) : (
      <ul>
        {latestNews.map((p: any) => (
          <li><time>{formatDate(p.date)}</time><span>{p.title}</span></li>
        ))}
      </ul>
    )}
    <a class="more" href={withBase('news/')}>お知らせ一覧を見る →</a>
  </section>

  <section class="cta-section">
    <h2>もっと知りたい方へ</h2>
    <div class="cta-links">
      <a href={withBase('works/')}>実績一覧を見る</a>
      <a href={withBase('contact/')}>お問い合わせ</a>
    </div>
  </section>
</BaseLayout>

<style>
  section { margin-bottom: 52px; }
  h2 { font-size: 1.15rem; margin: 0 0 16px; }

  .hero {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    padding: 64px 28px;
    margin-bottom: 52px;
    color: #fff;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-content { position: relative; max-width: min(46ch, 52%); }
  .hero h1 {
    font-family: var(--display-font);
    font-size: clamp(1.9rem, 4.4vw, 3.4rem);
    font-weight: 700;
    margin: 0 0 14px;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .hero .tagline {
    font-family: var(--display-font);
    font-size: 1.3rem;
    font-style: italic;
    opacity: 0.92;
    margin: 0 0 24px;
  }
  .cta {
    display: inline-block;
    background: #fff;
    color: #000;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 10px 22px;
    border-radius: 999px;
    text-decoration: none;
  }

  .agents h2 {
    font-family: var(--display-font);
    font-size: 1.9rem;
  }
  .agent-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 640px) {
    .agent-grid { grid-template-columns: repeat(1, 1fr); }
  }
  .agent-card {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px 16px;
    text-decoration: none;
    color: var(--text);
  }
  .agent-card:hover { border-color: var(--accent); }
  .agent-name {
    font-family: var(--display-font);
    font-size: 1.15rem;
    font-weight: 600;
    text-align: center;
  }

  .summary h2 {
    font-family: var(--display-font);
    font-size: 1.9rem;
  }
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--card-bg);
    box-shadow: 0 6px 20px rgba(0,0,0,0.06);
    padding: 4px;
  }
  table { width: 100%; border-collapse: collapse; font-size: 1rem; }
  th, td { text-align: left; padding: 16px 20px; border-bottom: 1px solid var(--border); }
  th { font-size: 0.78rem; color: var(--text-sub); text-transform: uppercase; letter-spacing: 0.04em; }
  tr:last-child td { border-bottom: none; }

  .news {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 26px;
    background: var(--accent-soft);
  }
  .news h2 {
    font-family: var(--display-font);
    font-size: 1.9rem;
  }
  .news ul { list-style: none; margin: 0 0 12px; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .news li { display: flex; gap: 14px; font-size: 0.88rem; }
  .news time { color: var(--text-sub); font-size: 0.78rem; white-space: nowrap; }
  .news .empty { font-size: 0.88rem; color: var(--text-sub); }
  .more { font-size: 0.85rem; color: var(--accent); text-decoration: none; }

  .cta-links { display: flex; gap: 14px; flex-wrap: wrap; }
  .cta-links a {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 8px 18px;
    border-radius: 999px;
    text-decoration: none;
  }
  .cta-links a:hover { background: var(--accent-soft); }
</style>
