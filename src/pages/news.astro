---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const newsPath = path.join(process.cwd(), 'public/data/news.json');
const newsData = JSON.parse(fs.readFileSync(newsPath, 'utf-8'));
const posts = [...newsData.posts].sort((a, b) => (a.date < b.date ? 1 : -1));

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Asia/Tokyo' });
}

function linkify(text: string) {
  const trailingPunct = /[。、,.)\]」]+$/;
  const parts: ({ text: string } | { url: string })[] = [];
  const matches = [...text.matchAll(/https?:\/\/\S+/g)];
  let lastIndex = 0;
  for (const m of matches) {
    let url = m[0];
    const start = m.index as number;
    const trail = url.match(trailingPunct);
    if (trail) url = url.slice(0, url.length - trail[0].length);
    if (start > lastIndex) parts.push({ text: text.slice(lastIndex, start) });
    parts.push({ url });
    lastIndex = start + url.length;
  }
  if (lastIndex < text.length) parts.push({ text: text.slice(lastIndex) });
  return parts;
}
---
<BaseLayout title="お知らせ" description="Agent Labの更新履歴">
  <h1>お知らせ</h1>

  {posts.length === 0 ? (
    <p class="empty panel">まだお知らせはありません。</p>
  ) : (
    <div class="list panel">
      {posts.map((p: any) => (
        <article class="post">
          <time class="date">{formatDate(p.date)}</time>
          <h2>{p.title}</h2>
          {p.body && (
            <p class="body">
              {linkify(p.body).map((part) =>
                'url' in part ? (
                  <a href={part.url} target="_blank" rel="noopener noreferrer">{part.url}</a>
                ) : (
                  part.text
                )
              )}
            </p>
          )}
        </article>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 24px; }
  .empty { font-size: 0.9rem; color: var(--text-sub); }
  .list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .panel {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.16);
  }
  .post {
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }
  .post:first-child {
    border-top: none;
    padding-top: 0;
  }
  .date {
    font-size: 0.75rem;
    color: var(--text-sub);
    display: block;
    margin-bottom: 4px;
  }
  h2 { font-size: 1rem; margin: 0 0 6px; }
  .body {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0;
    max-width: 66ch;
    white-space: pre-wrap;
  }
  .body a {
    color: var(--accent);
    word-break: break-all;
  }
</style>
