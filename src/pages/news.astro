---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const newsPath = path.join(process.cwd(), 'public/data/news.json');
const newsData = JSON.parse(fs.readFileSync(newsPath, 'utf-8'));
const posts = [...newsData.posts].sort((a, b) => (a.date < b.date ? 1 : -1));

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title="お知らせ" description="Agent Labの更新履歴">
  <h1>お知らせ</h1>
  <p class="lead">サイトの機能追加・変更など、訪問者から見て違いが分かる更新のみを記録しています。</p>

  {posts.length === 0 ? (
    <p class="empty">まだお知らせはありません。</p>
  ) : (
    <div class="list">
      {posts.map((p: any) => (
        <article class="post">
          <time class="date">{formatDate(p.date)}</time>
          <h2>{p.title}</h2>
          {p.body && <p class="body">{p.body}</p>}
        </article>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: var(--text-sub);
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .empty { font-size: 0.9rem; color: var(--text-sub); }
  .list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .post {
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }
  .date {
    font-size: 0.75rem;
    color: var(--text-sub);
    display: block;
    margin-bottom: 4px;
  }
  h2 { font-size: 1rem; margin: 0 0 6px; }
  .body {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0;
    max-width: 66ch;
    white-space: pre-wrap;
  }
</style>
