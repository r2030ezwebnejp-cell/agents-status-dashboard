---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: '01',
    name: 'AI Info Gather Agent',
    purpose: '最新のAI関連ニュースを収集し、note投稿用の原稿を作成する。',
    audience: 'ビジネスパーソン(非エンジニア)',
    frequency: '毎日',
  },
  {
    id: '02',
    name: 'Case Study Agent',
    purpose: '最新のAI活用成功事例をヒントに、まだAI導入が進んでいない業界へ向けた仮説的な解決策をケーススタディとして作成する。',
    audience: '業界問わず、AI活用のヒントを探しているビジネスパーソン',
    frequency: '毎日',
  },
  {
    id: '03',
    name: 'Self Management Agent',
    purpose: '日々の業務内容をフォームに入力し、週次でまとめて振り返れる形に整理・文書化する。',
    audience: '自分専用(非公開、社外・社内問わず共有しない)',
    frequency: '入力: 毎日 / 集計: 週次',
  },
  {
    id: '04',
    name: 'Business Email & Document Draft Agent',
    purpose: 'ビジネス現場で通用する英語力(資料作成・メール)を鍛える過程を、コンテンツとして発信する。',
    audience: 'ビジネス英語を学習中のビジネスパーソン',
    frequency: '毎日',
  },
  {
    id: '05',
    name: 'English Reading Agent',
    purpose: 'ビジネス現場で通用する英語の読解力を、精読力・専門文書への対応力・速読力の面から引き上げる。',
    audience: '自分専用の学習記録(非公開)',
    frequency: '毎日',
  },
  {
    id: '06',
    name: 'Business Knowledge Agent',
    purpose: 'ビジネスの現場で役立つ知識を、基礎から応用まで毎日3つ紹介する。',
    audience: 'ホワイトカラーのビジネスパーソン全般',
    frequency: '毎日',
  },
];
---
<BaseLayout title="サービス紹介" description="Agent Labで稼働する6体のAIエージェントの紹介">
  <h1>サービス紹介</h1>
  <p class="lead">Agent Labで稼働している6体のエージェントです。それぞれ役割・対象読者・実行頻度を明確に決めて運用しています。</p>

  <div class="list">
    {services.map((s) => (
      <section class="service">
        <div class="service-head">
          <h2>{s.id}. {s.name}</h2>
          <span class="freq">{s.frequency}</span>
        </div>
        <p class="purpose">{s.purpose}</p>
        <p class="audience"><span class="label">対象読者</span>{s.audience}</p>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: var(--text-sub);
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .service {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
  }
  .service-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  h2 { font-size: 1.02rem; margin: 0; }
  .freq {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .purpose {
    font-size: 0.88rem;
    line-height: 1.7;
    margin: 10px 0 8px;
    max-width: 66ch;
  }
  .audience {
    font-size: 0.82rem;
    color: var(--text-sub);
    margin: 0;
  }
  .label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1px 6px;
    margin-right: 8px;
  }
</style>
