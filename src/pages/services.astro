---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: '01',
    name: 'AI Info Gather Agent',
    purpose: '最新のAI関連ニュースを収集し、note投稿用の原稿を作成する。',
    audience: 'ビジネスパーソン(非エンジニア)',
  },
  {
    id: '02',
    name: 'Case Study Agent',
    purpose: '最新のAI活用成功事例をヒントに、まだAI導入が進んでいない業界へ向けた仮説的な解決策をケーススタディとして作成する。',
    audience: '業界問わず、AI活用のヒントを探しているビジネスパーソン',
  },
  {
    id: '04',
    name: 'Practical Business English Agent',
    purpose: 'ビジネス現場で通用する英語力(資料作成・メール)を鍛える過程を、コンテンツとして発信する。',
    audience: 'ビジネス英語を学習中のビジネスパーソン',
  },
  {
    id: '05',
    name: 'English Reading Agent',
    purpose: 'ビジネス現場で通用する英語の読解力を、精読力・専門文書への対応力・速読力の面から引き上げる。',
    audience: '自分専用の学習記録(非公開)',
  },
  {
    id: '06',
    name: 'Business Knowledge Agent',
    purpose: 'ビジネスの現場で役立つ知識を、基礎から応用まで毎日3つ紹介する。',
    audience: 'ホワイトカラーのビジネスパーソン全般',
  },
];

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.endsWith('/') ? base : base + '/'}${p}`;
---
<BaseLayout title="サービス紹介" description="Agent Labで稼働する5体のAIエージェントの紹介">
  <h1>サービス紹介</h1>
  <p class="lead">Agent Labで稼働している5体のエージェントです。それぞれ役割・対象読者・実行頻度を明確に決めて運用しています。</p>

  <div class="list">
    {services.map((s) => (
      <a class="service" href={withBase(`services/${s.id}/`)}>
        <div class="service-head">
          <h2>{s.name}</h2>
        </div>
        <p class="purpose">{s.purpose}</p>
        <p class="audience"><span class="label">対象読者</span>{s.audience}</p>
      </a>
    ))}
  </div>

  <section class="cta-section">
    <h2>同じようなエージェントを作りたい方へ</h2>
    <p class="cta-lead">ここで紹介しているエージェントを参考に、あなたの業務に合わせたAIエージェントの制作をご依頼いただけます。</p>
    <a class="cta-btn" href={withBase('request/')}>エージェント作成を依頼する →</a>
  </section>
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: #fff;
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .service {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .service:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  }
  .service-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  h2 { font-size: 1.02rem; margin: 0; }
  .purpose {
    font-size: 0.88rem;
    line-height: 1.7;
    margin: 10px 0 8px;
    max-width: 66ch;
  }
  .audience {
    font-size: 0.82rem;
    color: var(--text-sub);
    margin: 0;
  }
  .label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1px 6px;
    margin-right: 8px;
  }
  .cta-section {
    margin-top: 36px;
    text-align: center;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 32px 24px;
  }
  .cta-section h2 { font-size: 1.15rem; margin: 0 0 8px; }
  .cta-lead {
    font-size: 0.88rem;
    color: var(--text-sub);
    max-width: 50ch;
    margin: 0 auto 20px;
  }
  .cta-btn {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    padding: 11px 24px;
    border-radius: 999px;
    text-decoration: none;
  }
  .cta-btn:hover { opacity: 0.9; }
</style>
