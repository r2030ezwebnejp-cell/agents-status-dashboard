---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ダッシュボード" description="6体のAIエージェントの稼働状況ダッシュボード">
  <div class="updated" id="updated">読み込み中...</div>
  <div class="grid" id="grid"></div>
</BaseLayout>

<style is:global>
  .updated {
    font-size: 0.8rem;
    color: var(--text-sub);
    margin-bottom: 14px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.16);
  }
  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
  }
  .badge {
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 600;
    white-space: nowrap;
  }
  .badge.ok { background: color-mix(in srgb, var(--green) 18%, transparent); color: var(--green); }
  .badge.warn { background: color-mix(in srgb, var(--amber) 18%, transparent); color: var(--amber); }
  .badge.bad { background: color-mix(in srgb, var(--red) 18%, transparent); color: var(--red); }
  .badge.manual { background: color-mix(in srgb, var(--accent) 18%, transparent); color: var(--accent); }
  .row {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    padding: 5px 0;
    border-top: 1px solid var(--border);
  }
  .row:first-of-type { border-top: none; }
  .row .label { color: var(--text-sub); }
  .row .value { font-weight: 600; text-align: right; }
  .schedule {
    font-size: 0.75rem;
    color: var(--text-sub);
    margin-top: 2px;
  }
  .grid .detail-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 0.78rem;
    color: var(--accent);
    text-decoration: none;
  }
  .empty {
    text-align: center;
    color: var(--text-sub);
    padding: 40px 0;
  }
</style>

<script>
async function main() {
  const grid = document.getElementById('grid');
  const updatedEl = document.getElementById('updated');
  let data;
  try {
    const res = await fetch('../data/status.json?_=' + Date.now());
    data = await res.json();
  } catch (e) {
    grid.innerHTML = '<div class="empty">データの読み込みに失敗しました</div>';
    return;
  }

  updatedEl.textContent = data.updatedAt
    ? '最終更新: ' + formatDateTime(data.updatedAt)
    : '最終更新: まだ記録がありません';

  grid.innerHTML = data.agents.map(renderCard).join('');
}

function formatDateTime(iso) {
  const d = new Date(iso);
  return d.toLocaleString('ja-JP', { dateStyle: 'medium', timeStyle: 'short' });
}

function daysAgoLabel(iso) {
  const diffMs = Date.now() - new Date(iso).getTime();
  const days = Math.floor(diffMs / 86400000);
  if (days <= 0) return '今日';
  if (days === 1) return '1日前';
  return days + '日前';
}

function getMonthStart() {
  const now = new Date();
  return new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
}

function getWeekStart() {
  const now = new Date();
  const diffToMonday = (now.getDay() + 6) % 7; // days since most recent Monday
  return new Date(now.getFullYear(), now.getMonth(), now.getDate() - diffToMonday, 0, 0, 0, 0);
}

function computeCountSince(runs, sinceDate) {
  const sinceMs = sinceDate.getTime();
  return runs.filter(r => new Date(r.timestamp).getTime() >= sinceMs).length;
}

function computeStreak(runs) {
  const sorted = [...runs].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
  let streak = 0;
  for (const r of sorted) {
    if (r.status === 'success') streak++;
    else break;
  }
  return streak;
}

function renderCard(agent) {
  const runs = agent.runs || [];
  const lastRun = runs.length ? [...runs].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp))[0] : null;

  let badge = '<span class="badge manual">手動</span>';
  if (agent.type === 'auto') {
    if (!lastRun) {
      badge = '<span class="badge warn">未実行</span>';
    } else if (lastRun.status === 'success') {
      badge = '<span class="badge ok">正常</span>';
    } else {
      badge = '<span class="badge bad">失敗</span>';
    }
  }

  const rows = [];
  rows.push(row('直近実行', lastRun ? formatDateTime(lastRun.timestamp) + '(' + daysAgoLabel(lastRun.timestamp) + ')' : '記録なし'));
  rows.push(row('累計稼働回数', runs.length + '回'));
  rows.push(row('今月の稼働回数', computeCountSince(runs, getMonthStart()) + '回'));
  rows.push(row('今週の稼働回数', computeCountSince(runs, getWeekStart()) + '回'));
  rows.push(row('連続稼働', computeStreak(runs) + '回'));

  return `
    <div class="card">
      <div class="card-head">
        <div>
          <div class="card-title">${escapeHtml(agent.id)}. ${escapeHtml(agent.name)}</div>
          <div class="schedule">${escapeHtml(agent.scheduleLabel)}</div>
        </div>
        ${badge}
      </div>
      ${rows.join('')}
      <a class="detail-link" href="../agents/${escapeHtml(agent.id)}/">詳細を見る →</a>
    </div>
  `;
}

function row(label, value) {
  return `<div class="row"><span class="label">${escapeHtml(label)}</span><span class="value">${escapeHtml(value)}</span></div>`;
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, c => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
  }[c]));
}

main();
</script>
