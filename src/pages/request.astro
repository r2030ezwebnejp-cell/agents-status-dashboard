---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mojgewyq';

const settingsPath = path.join(process.cwd(), 'public/data/site-settings.json');
const siteSettings = JSON.parse(fs.readFileSync(settingsPath, 'utf-8'));
const acceptingRequests = siteSettings.acceptingRequests !== false;

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.endsWith('/') ? base : base + '/'}${p}`;
---
<BaseLayout title="エージェント作成を依頼する" description="あなたの業務に合わせたAIエージェントの制作をご依頼いただけます">
  <div class="intro">
  <h1>エージェント作成を依頼する</h1>
  <p class="lead">
    Agent Labでは、日々の業務を助けるAIエージェントの制作をご依頼いただけます。
    以下のフォームにご希望の内容をご記入ください。内容を確認のうえ、対応可否や
    お見積りについて折り返しメールにてご連絡します。
  </p>
  <p class="note">
    すべてのご依頼に対応できるとは限りません。あらかじめご了承ください。
  </p>

  <section class="info-block">
    <h2>対応できる範囲</h2>
    <p class="body">
      Claude Code(Anthropic社のAIコーディングツール)をベースに、日々の業務を助ける
      自動化エージェントの設計・構築を行っています。特に得意なのは次のような業務です。
    </p>
    <ul>
      <li>業界ニュース・競合動向などの情報収集と要約</li>
      <li>文書・原稿の下書き作成</li>
      <li>定型的な業務プロセスの自動化</li>
      <li>学習・振り返りの記録支援</li>
    </ul>
    <p class="body">
      Webサービスやスマホアプリの開発など、AIエージェントの範囲を超えるご依頼は
      対応できない場合があります。判断が難しい場合もまずはご相談ください。
    </p>
  </section>

  <section class="info-block">
    <h2>依頼の流れ</h2>
    <ol class="flow">
      <li><span class="flow-title">フォーム送信</span>下記フォームからご依頼内容をお送りください。</li>
      <li><span class="flow-title">内容確認・ヒアリング</span>必要に応じてメールで詳細をお伺いします。</li>
      <li><span class="flow-title">ご提案・お見積り</span>対応可否と概算費用・納期をご案内します。</li>
      <li><span class="flow-title">制作</span>ご要望に沿ってエージェントを設計・構築します。</li>
      <li><span class="flow-title">納品・動作確認</span>成果物をお渡しし、動作をご確認いただきます。</li>
    </ol>
  </section>

  <section class="info-block">
    <h2>よくある質問</h2>
    <div class="faq">
      <div class="faq-item">
        <p class="q">Q. 個人でも依頼できますか?</p>
        <p class="a">はい、個人・法人どちらからのご依頼も受け付けています。</p>
      </div>
      <div class="faq-item">
        <p class="q">Q. 料金の目安は?</p>
        <p class="a">内容によって異なるため、フォーム送信後に個別にお見積りします。フォームでは目安となる予算感を伺っています。</p>
      </div>
      <div class="faq-item">
        <p class="q">Q. 必ず対応してもらえますか?</p>
        <p class="a">内容や対応状況によってはお受けできない場合があります。あらかじめご了承ください。</p>
      </div>
      <div class="faq-item">
        <p class="q">Q. 機密情報を扱う業務でも依頼できますか?</p>
        <p class="a">内容によります。フォームの該当チェック欄からその旨をお知らせいただければ、対応可否も含めてご案内します。</p>
      </div>
      <div class="faq-item">
        <p class="q">Q. 納品後の保守や修正もお願いできますか?</p>
        <p class="a">ご相談のうえ、個別に対応します。</p>
      </div>
    </div>
  </section>

  <h2 class="form-heading">依頼フォーム</h2>
  </div>

  {!acceptingRequests ? (
    <p class="notice">
      現在、新規のご依頼受付を一時的に停止しています。再開まで今しばらくお待ちください。
    </p>
  ) : FORMSPREE_ENDPOINT ? (
    <div class="form-panel">
    <form action={FORMSPREE_ENDPOINT} method="POST" class="request-form">
      <input type="hidden" name="_subject" value="【Agent Lab】エージェント作成のご依頼">
      <input type="hidden" name="_next" value="https://r2030ezwebnejp-cell.github.io/agent-lab/request/thanks/">
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">

      <label for="name">お名前 <span class="req">必須</span></label>
      <input type="text" id="name" name="name" required>

      <label for="company">会社名・屋号</label>
      <input type="text" id="company" name="company" placeholder="任意">

      <label for="email">メールアドレス <span class="req">必須</span></label>
      <input type="email" id="email" name="email" required>

      <label for="purpose">作りたいエージェントの目的・概要 <span class="req">必須</span></label>
      <textarea id="purpose" name="purpose" required placeholder="例: 業界ニュースを毎朝収集して要約してほしい"></textarea>

      <label for="audience">対象読者・利用シーン</label>
      <input type="text" id="audience" name="audience" placeholder="任意">

      <label for="frequency">希望する実行頻度</label>
      <select id="frequency" name="frequency">
        <option value="毎日">毎日</option>
        <option value="週次">週次</option>
        <option value="都度実行">都度実行</option>
        <option value="相談したい" selected>相談したい</option>
      </select>

      <label for="budget">ご予算の目安</label>
      <select id="budget" name="budget">
        <option value="相談したい" selected>相談したい</option>
        <option value="〜5万円">〜5万円</option>
        <option value="5〜20万円">5〜20万円</option>
        <option value="20万円以上">20万円以上</option>
      </select>

      <label for="deadline">希望納期</label>
      <input type="text" id="deadline" name="deadline" placeholder="例: 2026年8月末まで、特になし など">

      <label class="checkbox-row">
        <input type="checkbox" name="confidential" value="含む可能性がある">
        業務上の機密情報(取引先名・金額・個人情報等)を扱う可能性がある
      </label>

      <label for="notes">その他ご要望</label>
      <textarea id="notes" name="notes" placeholder="任意"></textarea>

      <p class="consent">
        送信すると、<a href={withBase('privacy/')}>プライバシーポリシー</a>に
        同意したものとみなされます。
      </p>
      <button type="submit" class="btn">依頼内容を送信する</button>
    </form>
    </div>
  ) : (
    <p class="notice">現在依頼フォームは準備中です。</p>
  )}
</BaseLayout>

<script is:inline>
  window.addEventListener('pageshow', () => {
    document.querySelector('.request-form')?.reset();
  });
</script>

<style>
  :global(main) { max-width: none; }
  .intro { max-width: 640px; margin: 0 auto; }
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: #fff;
    max-width: 60ch;
    margin: 0 0 10px;
    line-height: 1.7;
  }
  .note {
    font-size: 0.8rem;
    color: #fff;
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .info-block {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 22px;
    margin-bottom: 16px;
    max-width: 640px;
  }
  .info-block h2 { font-size: 1rem; margin: 0 0 12px; }
  .info-block .body {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--text);
    margin: 0 0 10px;
  }
  .info-block ul {
    margin: 0 0 10px;
    padding-left: 1.3em;
    font-size: 0.88rem;
    line-height: 1.8;
  }
  .flow {
    margin: 0;
    padding-left: 1.3em;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .flow li { font-size: 0.88rem; line-height: 1.6; }
  .flow-title {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--accent);
  }
  .faq { display: flex; flex-direction: column; gap: 14px; }
  .faq-item .q { font-size: 0.88rem; font-weight: 700; margin: 0 0 4px; }
  .faq-item .a { font-size: 0.86rem; color: var(--text-sub); line-height: 1.7; margin: 0; }
  .form-heading { font-size: 1.05rem; margin: 32px 0 14px; }
  .form-panel {
    width: calc(50vw + 52px);
    max-width: 100%;
    margin: 0 auto;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 26px;
    box-sizing: border-box;
  }
  .request-form {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
  }
  label {
    font-size: 0.78rem;
    color: #1c1f26;
    margin-top: 10px;
  }
  .req {
    color: #dc2626;
    font-weight: 700;
    margin-left: 4px;
  }
  input, textarea, select {
    width: 100%;
    box-sizing: border-box;
    padding: 9px 11px;
    border-radius: 7px;
    border: 1px solid #d1d5db;
    background: #fff;
    color: #1c1f26;
    font-size: 0.9rem;
    font-family: inherit;
  }
  textarea { min-height: 90px; resize: vertical; }
  .checkbox-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #1c1f26;
    margin-top: 14px;
  }
  .checkbox-row input { width: auto; padding: 0; }
  .consent {
    font-size: 0.76rem;
    color: #4b5563;
    margin: 16px 0 0;
  }
  .consent a { color: #1D5FD6; }
  .btn {
    margin-top: 20px;
    align-self: flex-start;
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }
  .notice {
    font-size: 0.88rem;
    color: var(--text-sub);
  }
  @media (max-width: 640px) {
    .form-panel { width: 100%; }
  }
</style>
