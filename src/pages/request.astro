---
import BaseLayout from '../layouts/BaseLayout.astro';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mojgewyq';
---
<BaseLayout title="エージェント作成を依頼する" description="あなたの業務に合わせたAIエージェントの制作をご依頼いただけます">
  <h1>エージェント作成を依頼する</h1>
  <p class="lead">
    Agent Labでは、日々の業務を助けるAIエージェントの制作をご依頼いただけます。
    以下のフォームにご希望の内容をご記入ください。内容を確認のうえ、対応可否や
    お見積りについて折り返しメールにてご連絡します。
  </p>
  <p class="note">
    すべてのご依頼に対応できるとは限りません。あらかじめご了承ください。
  </p>

  {FORMSPREE_ENDPOINT ? (
    <form action={FORMSPREE_ENDPOINT} method="POST" class="request-form">
      <input type="hidden" name="_subject" value="【Agent Lab】エージェント作成のご依頼">

      <label for="name">お名前 <span class="req">必須</span></label>
      <input type="text" id="name" name="name" required>

      <label for="company">会社名・屋号</label>
      <input type="text" id="company" name="company" placeholder="任意">

      <label for="email">メールアドレス <span class="req">必須</span></label>
      <input type="email" id="email" name="email" required>

      <label for="purpose">作りたいエージェントの目的・概要 <span class="req">必須</span></label>
      <textarea id="purpose" name="purpose" required placeholder="例: 業界ニュースを毎朝収集して要約してほしい"></textarea>

      <label for="audience">対象読者・利用シーン</label>
      <input type="text" id="audience" name="audience" placeholder="任意">

      <label for="frequency">希望する実行頻度</label>
      <select id="frequency" name="frequency">
        <option value="毎日">毎日</option>
        <option value="週次">週次</option>
        <option value="都度実行">都度実行</option>
        <option value="相談したい" selected>相談したい</option>
      </select>

      <label for="budget">ご予算の目安</label>
      <select id="budget" name="budget">
        <option value="相談したい" selected>相談したい</option>
        <option value="〜5万円">〜5万円</option>
        <option value="5〜20万円">5〜20万円</option>
        <option value="20万円以上">20万円以上</option>
      </select>

      <label for="deadline">希望納期</label>
      <input type="text" id="deadline" name="deadline" placeholder="例: 2026年8月末まで、特になし など">

      <label class="checkbox-row">
        <input type="checkbox" name="confidential" value="含む可能性がある">
        業務上の機密情報(取引先名・金額・個人情報等)を扱う可能性がある
      </label>

      <label for="notes">その他ご要望</label>
      <textarea id="notes" name="notes" placeholder="任意"></textarea>

      <button type="submit" class="btn">依頼内容を送信する</button>
    </form>
  ) : (
    <p class="notice">現在依頼フォームは準備中です。</p>
  )}
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: var(--text-sub);
    max-width: 60ch;
    margin: 0 0 10px;
    line-height: 1.7;
  }
  .note {
    font-size: 0.8rem;
    color: var(--text-sub);
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .request-form {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 480px;
  }
  label {
    font-size: 0.78rem;
    color: var(--text-sub);
    margin-top: 10px;
  }
  .req {
    color: var(--accent);
    font-weight: 700;
    margin-left: 4px;
  }
  input, textarea, select {
    padding: 9px 11px;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    color: var(--text);
    font-size: 0.9rem;
    font-family: inherit;
  }
  textarea { min-height: 90px; resize: vertical; }
  .checkbox-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text);
    margin-top: 14px;
  }
  .checkbox-row input { width: auto; padding: 0; }
  .btn {
    margin-top: 20px;
    align-self: flex-start;
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }
  .notice {
    font-size: 0.88rem;
    color: var(--text-sub);
  }
</style>
