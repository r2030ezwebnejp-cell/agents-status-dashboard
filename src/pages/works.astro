---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const worksPath = path.join(process.cwd(), 'public/data/works.json');
const worksData = JSON.parse(fs.readFileSync(worksPath, 'utf-8'));
const works = worksData.works as any[];

const AGENTS = [
  { id: '01', name: 'AI Info Gather Agent' },
  { id: '02', name: 'Case Study Agent' },
  { id: '04', name: 'Practical Business English Agent' },
  { id: '06', name: 'Business Knowledge Agent' },
];

function toDateObj(dateStr: string) { return new Date(dateStr + 'T00:00:00Z'); }

function computeStreak(dates: string[]) {
  // dates: sorted descending (newest first)
  if (dates.length === 0) return 0;
  let streak = 1;
  for (let i = 0; i < dates.length - 1; i++) {
    const diffDays = (toDateObj(dates[i]).getTime() - toDateObj(dates[i + 1]).getTime()) / 86400000;
    if (diffDays === 1) streak++; else break;
  }
  return streak;
}

const summaries = AGENTS.map((a) => {
  const agentWorks = works.filter((w) => w.agent_id === a.id);
  const dates = [...new Set(agentWorks.map((w) => w.date))].sort((x, y) => (x < y ? 1 : -1));
  return {
    ...a,
    total: agentWorks.length,
    streak: computeStreak(dates),
  };
});

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.endsWith('/') ? base : base + '/'}${p}`;
---
<BaseLayout title="note記事" description="Agent Labが生成したnote記事の実績サマリー">
  <h1>note記事</h1>
  <p class="lead">エージェントごとの投稿実績です。「記事一覧を見る」をクリックすると、投稿したnote記事へのリンクがあります。</p>

  <div class="list">
    {summaries.map((s) => (
      <article class="summary-card">
        <div class="summary-head">
          <h2>{s.name}</h2>
        </div>
        <div class="stats">
          <div class="stat">
            <span class="stat-value">{s.total}</span>
            <span class="stat-label">累計投稿数</span>
          </div>
          <div class="stat">
            <span class="stat-value">{s.streak}</span>
            <span class="stat-label">連続投稿数</span>
          </div>
        </div>
        <a class="btn" href={withBase(`works/${s.id}/`)}>記事一覧を見る →</a>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-size: 1.5rem; margin: 0 0 8px; }
  .lead {
    font-size: 0.95rem;
    color: #fff;
    max-width: 60ch;
    margin: 0 0 28px;
  }
  .list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }
  .summary-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  h2 { font-size: 1rem; margin: 0; }
  .stats {
    display: flex;
    gap: 24px;
  }
  .stat {
    display: flex;
    flex-direction: column;
  }
  .stat-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.72rem;
    color: var(--text-sub);
  }
  .btn {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-top: auto;
  }
  .btn:hover { text-decoration: underline; }
</style>
