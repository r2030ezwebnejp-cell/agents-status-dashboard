---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const services = [
    {
      id: '01',
      name: 'AI Info Gather Agent',
      purpose: '最新のAI関連ニュースを収集し、note投稿用の原稿を作成する。',
      audience: 'ビジネスパーソン(非エンジニア)',
    },
    {
      id: '02',
      name: 'Case Study Agent',
      purpose: '最新のAI活用成功事例をヒントに、まだAI導入が進んでいない業界へ向けた仮説的な解決策をケーススタディとして作成する。',
      audience: '業界問わず、AI活用のヒントを探しているビジネスパーソン',
    },
    {
      id: '04',
      name: 'Practical Business English Agent',
      purpose: 'ビジネス現場で通用する英語力(資料作成・メール)を鍛える過程を、コンテンツとして発信する。',
      audience: 'ビジネス英語を学習中のビジネスパーソン',
    },
    {
      id: '05',
      name: 'English Reading Agent',
      purpose: 'ビジネス現場で通用する英語の読解力を、精読力・専門文書への対応力・速読力の面から引き上げる。',
      audience: '自分専用の学習記録(非公開)',
    },
    {
      id: '06',
      name: 'Business Knowledge Agent',
      purpose: 'ビジネスの現場で役立つ知識を、基礎から応用まで毎日3つ紹介する。',
      audience: 'ホワイトカラーのビジネスパーソン全般',
    },
  ];
  return services.map((s) => ({
    params: { id: s.id },
    props: { service: s },
  }));
}

const { service } = Astro.props;
---
<BaseLayout title={service.name} description={service.purpose}>
  <p class="back"><a href="../">← サービス紹介に戻る</a></p>

  <div class="head">
    <h1>{service.name}</h1>
  </div>

  <section class="panel">
    <h2>概要</h2>
    <p class="purpose">{service.purpose}</p>
    <p class="audience"><span class="label">対象読者</span>{service.audience}</p>
  </section>

  <p class="notice">詳細な内容は今後追加していく予定です。</p>
</BaseLayout>

<style>
  .back { font-size: 0.82rem; margin: 0 0 12px; }
  .back a { color: var(--accent); text-decoration: none; }
  .head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }
  h1 { font-size: 1.4rem; margin: 0; }
  .panel {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 22px 20px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.16);
  }
  h2 { font-size: 1.05rem; margin: 0 0 12px; }
  .purpose {
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0 0 12px;
    max-width: 66ch;
  }
  .audience {
    font-size: 0.85rem;
    color: var(--text-sub);
    margin: 0;
  }
  .label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1px 6px;
    margin-right: 8px;
  }
  .notice {
    font-size: 0.8rem;
    color: var(--text-sub);
    margin-top: 16px;
  }
</style>
