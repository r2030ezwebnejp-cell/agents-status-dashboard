---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Agent Lab — 6体のAIエージェントが動く実験場" } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const settingsPath = path.join(process.cwd(), 'public/data/site-settings.json');
const siteSettings = JSON.parse(fs.readFileSync(settingsPath, 'utf-8'));
const theme = siteSettings.theme === 'light' || siteSettings.theme === 'dark' ? siteSettings.theme : null;
---

<!DOCTYPE html>
<html lang="ja" data-theme={theme}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} — Agent Lab</title>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a class="brand" href={`${base}`}>Agent Lab</a>
      <nav class="site-nav">
        <a href={`${base}`}>トップ</a>
        <a href={`${base}services/`}>サービス紹介</a>
        <a href={`${base}works/`}>実績一覧</a>
        <a href={`${base}news/`}>お知らせ</a>
        <a href={`${base}about/`}>概要</a>
        <a href={`${base}dashboard/`}>ダッシュボード</a>
        <a href={`${base}settings/`} id="nav-settings" hidden>設定</a>
        <a class="nav-cta" href={`${base}contact/`}>お問い合わせ</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>Agent Lab — 6体のAIエージェントが動く実験場</p>
  </footer>

  <script>
    const ADMIN_KEY = 'agentlab-admin';
    if (/\/adminpage\/?$/.test(window.location.pathname)) {
      localStorage.setItem(ADMIN_KEY, '1');
    }
    if (localStorage.getItem(ADMIN_KEY) === '1') {
      document.getElementById('nav-settings')?.removeAttribute('hidden');
    }
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #f5f6f8;
    --card-bg: #ffffff;
    --text: #1c1f26;
    --text-sub: #6b7280;
    --border: #e5e7eb;
    --green: #16a34a;
    --amber: #d97706;
    --red: #dc2626;
    --accent: #1D5FD6;
    --accent-soft: #e8f0fd;
    --header-bg: #14161f;
    --header-text: #f5f6f8;
    --header-border: #262a38;
    --display-font: Didot, "Bodoni MT", "Didot LT STD", "Big Caslon", Georgia, "Times New Roman", serif;
    /* AI futuristic glow palette, sampled top -> bottom of the page */
    --ai-glow-1: #4f7dfa;
    --ai-glow-2: #7c5cff;
    --ai-glow-3: #22d3ee;
    --ai-glow-4: #d946ef;
    --ai-glow-5: #14b8a6;
    --ai-glow-alpha: 28%;
    --bg-grad-1: #eef2ff;
    --bg-grad-2: #ece7ff;
    --bg-grad-3: #e2f7fa;
    --bg-grad-4: #fbe9fb;
    --bg-grad-5: #eafaf5;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1b1e28;
      --card-bg: #262a36;
      --text: #e5e7eb;
      --text-sub: #9ca3af;
      --border: #363b49;
      --green: #4ade80;
      --amber: #fbbf24;
      --red: #f87171;
      --accent: #6ea3f2;
      --accent-soft: #1a2740;
      --ai-glow-alpha: 55%;
      --bg-grad-1: #060815;
      --bg-grad-2: #100f30;
      --bg-grad-3: #0a2233;
      --bg-grad-4: #1c1033;
      --bg-grad-5: #040508;
    }
  }
  :root[data-theme="dark"] {
    --bg: #1b1e28; --card-bg: #262a36; --text: #e5e7eb; --text-sub: #9ca3af;
    --border: #363b49; --green: #4ade80; --amber: #fbbf24; --red: #f87171;
    --accent: #6ea3f2; --accent-soft: #1a2740;
    --ai-glow-alpha: 55%;
    --bg-grad-1: #060815; --bg-grad-2: #100f30; --bg-grad-3: #0a2233;
    --bg-grad-4: #1c1033; --bg-grad-5: #040508;
  }
  :root[data-theme="light"] {
    --bg: #f5f6f8; --card-bg: #ffffff; --text: #1c1f26; --text-sub: #6b7280;
    --border: #e5e7eb; --green: #16a34a; --amber: #d97706; --red: #dc2626;
    --accent: #1D5FD6; --accent-soft: #e8f0fd;
    --ai-glow-alpha: 28%;
    --bg-grad-1: #eef2ff; --bg-grad-2: #ece7ff; --bg-grad-3: #e2f7fa;
    --bg-grad-4: #fbe9fb; --bg-grad-5: #eafaf5;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif;
    background-color: var(--bg);
    background-image:
      radial-gradient(circle at 12% 6%, color-mix(in srgb, var(--ai-glow-1) var(--ai-glow-alpha), transparent), transparent 70%),
      radial-gradient(circle at 88% 16%, color-mix(in srgb, var(--ai-glow-2) var(--ai-glow-alpha), transparent), transparent 70%),
      radial-gradient(circle at 15% 40%, color-mix(in srgb, var(--ai-glow-3) var(--ai-glow-alpha), transparent), transparent 70%),
      radial-gradient(circle at 85% 62%, color-mix(in srgb, var(--ai-glow-4) var(--ai-glow-alpha), transparent), transparent 70%),
      radial-gradient(circle at 20% 86%, color-mix(in srgb, var(--ai-glow-5) var(--ai-glow-alpha), transparent), transparent 70%),
      radial-gradient(circle at 80% 100%, color-mix(in srgb, var(--ai-glow-2) var(--ai-glow-alpha), transparent), transparent 70%),
      linear-gradient(180deg,
        var(--bg-grad-1) 0%,
        var(--bg-grad-2) 25%,
        var(--bg-grad-3) 50%,
        var(--bg-grad-4) 75%,
        var(--bg-grad-5) 100%);
    background-repeat: no-repeat;
    background-size:
      900px 900px,
      950px 950px,
      850px 850px,
      900px 900px,
      850px 850px,
      950px 950px,
      100% 100%;
    background-attachment: scroll;
  }
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 20px 16px 60px;
  }
</style>

<style>
  .site-header {
    width: 100%;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
  }
  .header-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px 24px;
  }
  .brand {
    font-family: var(--display-font);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: 0.02em;
    color: var(--header-text);
    text-decoration: none;
    text-align: left;
    margin-right: auto;
  }
  .site-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 26px;
  }
  .site-nav a {
    font-size: 1rem;
    color: var(--header-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-nav a:hover {
    color: #f5b942;
  }
  .site-nav .nav-cta {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--header-text);
    border: 1.5px solid var(--header-text);
    border-radius: 999px;
    padding: 7px 22px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .site-nav .nav-cta:hover {
    background: var(--header-text);
    color: var(--header-bg);
  }
  .site-footer {
    max-width: 960px;
    margin: 40px auto 0;
    padding: 16px;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-sub);
  }
</style>
