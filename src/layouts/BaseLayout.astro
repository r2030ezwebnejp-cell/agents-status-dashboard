---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Agent Lab — 5体のAIエージェントが動く実験場" } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const settingsPath = path.join(process.cwd(), 'public/data/site-settings.json');
const siteSettings = JSON.parse(fs.readFileSync(settingsPath, 'utf-8'));
const theme = siteSettings.theme === 'light' || siteSettings.theme === 'dark' ? siteSettings.theme : null;
---

<!DOCTYPE html>
<html lang="ja" data-theme={theme}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <title>{title} — Agent Lab</title>
</head>
<body style={`--bg-photo: url(${base}images/site-background.png)`}>
  <header class="site-header">
    <div class="header-inner">
      <a class="brand" href={`${base}`}>Agent Lab</a>
      <nav class="site-nav">
        <a href={`${base}`}>トップ</a>
        <a href={`${base}services/`}>サービス紹介</a>
        <a href={`${base}works/`}>note記事</a>
        <a href={`${base}news/`}>お知らせ</a>
        <a href={`${base}dashboard/`}>ダッシュボード</a>
        <a class="nav-cta" href={`${base}contact/`}>お問い合わせ</a>
        <a href={`${base}settings/`} id="nav-settings" hidden>設定</a>
        <a class="nav-cta" href={`${base}request/`}>依頼する</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <nav class="footer-nav">
        <a href={`${base}terms/`}>利用規約</a>
        <a href={`${base}privacy/`}>プライバシーポリシー</a>
      </nav>
      <p class="copyright">&copy; Agent Lab</p>
    </div>
  </footer>

  <script>
    if (/\/adminpage\/?$/.test(window.location.pathname)) {
      document.getElementById('nav-settings')?.removeAttribute('hidden');
    }
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #f5f6f8;
    --card-bg: #ffffff;
    --text: #1c1f26;
    --text-sub: #6b7280;
    --border: #e5e7eb;
    --green: #16a34a;
    --amber: #d97706;
    --red: #dc2626;
    --accent: #1D5FD6;
    --accent-soft: #e8f0fd;
    --header-bg: #14161f;
    --header-text: #f5f6f8;
    --header-border: #262a38;
    --display-font: Didot, "Bodoni MT", "Didot LT STD", "Big Caslon", Georgia, "Times New Roman", serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1b1e28;
      --card-bg: #262a36;
      --text: #e5e7eb;
      --text-sub: #9ca3af;
      --border: #363b49;
      --green: #4ade80;
      --amber: #fbbf24;
      --red: #f87171;
      --accent: #6ea3f2;
      --accent-soft: #1a2740;
    }
  }
  :root[data-theme="dark"] {
    --bg: #1b1e28; --card-bg: #262a36; --text: #e5e7eb; --text-sub: #9ca3af;
    --border: #363b49; --green: #4ade80; --amber: #fbbf24; --red: #f87171;
    --accent: #6ea3f2; --accent-soft: #1a2740;
  }
  :root[data-theme="light"] {
    --bg: #f5f6f8; --card-bg: #ffffff; --text: #1c1f26; --text-sub: #6b7280;
    --border: #e5e7eb; --green: #16a34a; --amber: #d97706; --red: #dc2626;
    --accent: #1D5FD6; --accent-soft: #e8f0fd;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif;
    background-color: var(--bg);
    background-image: var(--bg-photo);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center top;
    background-attachment: fixed;
  }
  main {
    flex: 1 0 auto;
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    padding: 20px 16px 60px;
  }
</style>

<style>
  .site-header {
    width: 100%;
    flex-shrink: 0;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
  }
  .header-inner {
    width: 100%;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px 24px;
  }
  .brand {
    font-family: var(--display-font);
    font-weight: 700;
    font-size: 2.1rem;
    letter-spacing: 0.02em;
    color: var(--header-text);
    text-decoration: none;
    text-align: left;
    margin-left: 40px;
    margin-right: auto;
  }
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 10px 26px;
  }
  .site-nav a {
    font-size: 1rem;
    color: var(--header-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-nav a:hover {
    color: #f5b942;
  }
  .site-nav .nav-cta {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--header-text);
    border: 1.5px solid var(--header-text);
    border-radius: 999px;
    padding: 7px 22px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .site-nav .nav-cta:hover {
    background: var(--header-text);
    color: var(--header-bg);
  }

  .site-footer {
    width: 100%;
    flex-shrink: 0;
    background: var(--header-bg);
    border-top: 1px solid var(--header-border);
    margin-top: 40px;
  }
  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px 24px;
  }
  .footer-nav {
    display: flex;
    gap: 20px;
  }
  .footer-nav a {
    font-size: 0.92rem;
    color: var(--header-text);
    opacity: 0.92;
    text-decoration: none;
  }
  .footer-nav a:hover { opacity: 1; }
  .copyright {
    font-size: 0.88rem;
    color: var(--header-text);
    opacity: 0.85;
    margin: 0;
  }
</style>
